{
  "framework": null,
  "buildCommand": "node vercel-build.mjs",
  "outputDirectory": "dist",
  "installCommand": "cd ../.. && pnpm install",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "build": {
    "env": {
      "BASE_PATH": "/",
      "PORT": "3000"
    }
  }
}
